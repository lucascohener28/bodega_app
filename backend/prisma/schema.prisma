generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Categoria {
  id        Int      @id @default(autoincrement())
  nombre    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productos Producto[]
}

model Proveedor {
  id        Int      @id @default(autoincrement())
  nombre    String
  telefono  String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingresos IngresoMercaderia[]
  productos Producto[]
  liquidaciones Liquidacion[]
}

model Producto {
  id             Int      @id @default(autoincrement())
  nombre         String
  codigo         String   @unique
  precioVenta    Float
  costoProveedor Float
  stockActual    Int      @default(0)
  stockMinimo    Int      @default(0)
  activo         Boolean  @default(true)

  manejaPack     Boolean  @default(false)
  unidadesPorPack Int?

  detallesIngreso     DetalleIngresoMercaderia[]
  detallesVenta       DetalleVenta[]
  movimientos         MovimientoInventario[]
  detallesLiquidacion DetalleLiquidacion[]

  categoriaId Int
  proveedorId Int

  categoria Categoria @relation(fields: [categoriaId], references: [id])
  proveedor Proveedor @relation(fields: [proveedorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IngresoMercaderia {
  id             Int                       @id @default(autoincrement())
  fecha          DateTime                  @default(now())
  tipoIngreso    TipoIngreso
  observacion    String?
  proveedorId    Int
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  proveedor      Proveedor                 @relation(fields: [proveedorId], references: [id])
  detalles       DetalleIngresoMercaderia[]
}

model DetalleIngresoMercaderia {
  id                Int               @id @default(autoincrement())
  cantidad          Int
  costoUnitario     Float
  subtotal          Float
  ingresoId         Int
  productoId        Int
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  ingreso           IngresoMercaderia @relation(fields: [ingresoId], references: [id])
  producto          Producto          @relation(fields: [productoId], references: [id])
}

model Venta {
  id              Int            @id @default(autoincrement())
  fecha           DateTime       @default(now())
  total           Float
  metodoPago      MetodoPago
  observacion     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  detalles        DetalleVenta[]
}

model DetalleVenta {
  id              Int          @id @default(autoincrement())
  cantidad        Int
  precioUnitario  Float
  subtotal        Float
  ventaId         Int
  productoId      Int
  liquidacionId   Int?
  liquidado       Boolean      @default(false)
  liquidadoAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  venta           Venta        @relation(fields: [ventaId], references: [id])
  producto        Producto     @relation(fields: [productoId], references: [id])
  liquidacion     Liquidacion? @relation(fields: [liquidacionId], references: [id])
}

model MovimientoInventario {
  id              Int              @id @default(autoincrement())
  tipoMovimiento  TipoMovimiento
  cantidad        Int
  stockAnterior   Int?
  stockNuevo      Int?
  referenciaTipo  String?
  referenciaId    Int?
  observacion     String?
  productoId      Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  producto        Producto         @relation(fields: [productoId], references: [id])
}

enum TipoIngreso {
  CONSIGNACION
  COMPRA_DIRECTA
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  QR
  MIXTO
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE
}

model Liquidacion {
  id              Int                 @id @default(autoincrement())
  fecha           DateTime            @default(now())
  periodo         String
  totalPagar      Float
  cerrada         Boolean             @default(false)
  fechaCierre     DateTime?
  observacion     String?
  proveedorId     Int
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  proveedor       Proveedor           @relation(fields: [proveedorId], references: [id])
  detalles        DetalleLiquidacion[]
  detallesVenta   DetalleVenta[]
}

model DetalleLiquidacion {
  id                Int          @id @default(autoincrement())
  cantidadRecibida  Int
  cantidadVendida   Int
  cantidadRestante  Int
  costoUnitario     Float
  subtotal          Float
  liquidacionId     Int
  productoId        Int
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  liquidacion       Liquidacion  @relation(fields: [liquidacionId], references: [id])
  producto          Producto     @relation(fields: [productoId], references: [id])
}

model Usuario {
  id        String   @id @default(cuid())
  nombre    String
  username  String   @unique
  email     String?  @unique
  password  String
  rol       Rol      @default(CAJERO)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cajasAbiertas CajaDiaria[]     @relation("CajaAbiertaPor")
  cajasCerradas CajaDiaria[]     @relation("CajaCerradaPor")
  movimientosCaja MovimientoCaja[]
}

enum Rol {
  ADMIN
  CAJERO
}

model CajaDiaria {
  id                 String       @id @default(cuid())
  fecha              DateTime     @default(now())
  estado             EstadoCaja   @default(ABIERTA)
  montoInicial       Int
  montoFinal         Int?
  totalEfectivo      Int          @default(0)
  totalQR            Int          @default(0)
  totalTransferencia Int          @default(0)
  totalMixto         Int          @default(0)
  totalEsperado      Int?
  diferencia         Int?
  observacionApertura String?
  observacionCierre String?
  abiertaPorId       String
  cerradaPorId       String?
  abiertaEn          DateTime     @default(now())
  cerradaEn          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  abiertaPor         Usuario      @relation("CajaAbiertaPor", fields: [abiertaPorId], references: [id])
  cerradaPor         Usuario?     @relation("CajaCerradaPor", fields: [cerradaPorId], references: [id])
  movimientos        MovimientoCaja[]
}

model MovimientoCaja {
  id          String   @id @default(cuid())
  cajaId      String
  tipo        TipoMovimientoCaja
  monto       Int
  concepto    String
  observacion String?
  creadoPorId String
  createdAt   DateTime @default(now())

  caja        CajaDiaria @relation(fields: [cajaId], references: [id])
  creadoPor   Usuario   @relation(fields: [creadoPorId], references: [id])
}

enum EstadoCaja {
  ABIERTA
  CERRADA
}

enum TipoMovimientoCaja {
  INGRESO
  EGRESO
  RETIRO
}
